# Database Mode
# Set to 'false' to run without database (uses in-memory mock data)
USE_DATABASE=true

# Database (only needed when USE_DATABASE=true)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=myapp

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server
PORT=3000
